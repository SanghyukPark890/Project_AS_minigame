<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
<title>데스티나의 발자취 - Project AS Minigame</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; user-select: none; }
  html, body { width: 100%; height: 100%; overflow: hidden; background: #222; font-family: "Pretendard", "Noto Sans KR", sans-serif; }
  #game-wrap {
    position: relative;
    width: 100vw; height: 100vh;
    max-width: 540px; max-height: 720px;
    margin: 0 auto;
    background: linear-gradient(180deg, #7ec2ea 0%, #5aa8d6 100%);
    overflow: hidden;
    border: 4px solid #1a1a1a;
    border-radius: 8px;
  }
  canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: block; }

  /* HUD */
  #hud {
    position: absolute; top: 10px; left: 50%; transform: translateX(-50%);
    background: linear-gradient(180deg, rgba(10,30,60,0.88), rgba(5,15,35,0.88));
    color: #fff;
    padding: 10px 22px;
    border-radius: 24px;
    font-size: 18px; font-weight: bold;
    letter-spacing: 1.5px;
    z-index: 10;
    white-space: nowrap;
    border: 1px solid rgba(120,180,230,0.4);
    box-shadow: 0 4px 16px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.1);
    display: none;
  }
  #hud.visible { display: block; }
  #hud .count { color: #ffd84d; }

  /* D-pad */
  #dpad {
    position: absolute;
    right: 24px; bottom: 24px;
    width: 160px; height: 160px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, rgba(240,248,255,0.7), rgba(180,210,235,0.5));
    border: 3px solid rgba(47,111,159,0.85);
    z-index: 10;
    touch-action: none;
    box-shadow: 0 6px 20px rgba(0,0,0,0.35), inset 0 2px 6px rgba(255,255,255,0.5);
    display: none;
  }
  #dpad.visible { display: block; }
  #dpad .center {
    position: absolute; top: 50%; left: 50%;
    width: 48px; height: 48px; margin: -24px 0 0 -24px;
    border-radius: 50%;
    background: #fff;
    border: 2px solid #2f6f9f;
  }
  .arrow {
    position: absolute;
    width: 0; height: 0;
    color: #2f4a5c;
  }
  .arrow.up    { top: 10px;    left: 50%; transform: translateX(-50%); border-left: 10px solid transparent; border-right: 10px solid transparent; border-bottom: 14px solid currentColor; }
  .arrow.down  { bottom: 10px; left: 50%; transform: translateX(-50%); border-left: 10px solid transparent; border-right: 10px solid transparent; border-top: 14px solid currentColor; }
  .arrow.left  { left: 10px;   top: 50%;  transform: translateY(-50%); border-top: 10px solid transparent; border-bottom: 10px solid transparent; border-right: 14px solid currentColor; }
  .arrow.right { right: 10px;  top: 50%;  transform: translateY(-50%); border-top: 10px solid transparent; border-bottom: 10px solid transparent; border-left: 14px solid currentColor; }

  /* 컷신 & 결과 */
  .overlay {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.8);
    display: none;
    align-items: center; justify-content: center;
    z-index: 20;
    flex-direction: column;
    color: #fff;
    text-align: center;
    padding: 20px;
  }
  .overlay.show { display: flex; }
  .cutscene-frame {
    width: 280px; height: 340px;
    border: 6px solid #f5d77a;
    border-radius: 12px;
    background: linear-gradient(180deg, #ffe9a8, #f5c56b);
    box-shadow: 0 0 40px rgba(255, 216, 77, 0.6);
    overflow: hidden;
    position: relative;
    margin-bottom: 18px;
  }
  .cutscene-frame svg, .cutscene-frame img, .cutscene-frame video { width: 100%; height: 100%; display: block; object-fit: cover; }
  .cutscene-title {
    font-size: 28px; font-weight: bold; color: #ffd84d;
    margin-bottom: 10px; letter-spacing: 2px;
    text-shadow: 0 2px 8px rgba(0,0,0,0.6);
  }
  .cutscene-text {
    font-size: 16px; line-height: 1.5;
    margin-bottom: 18px; max-width: 320px;
  }
  .btn {
    padding: 12px 30px;
    background: linear-gradient(180deg, #ffd84d, #e6a516);
    color: #2a1a00;
    border: 2px solid #a67800;
    border-radius: 24px;
    font-size: 16px; font-weight: bold;
    cursor: pointer;
    letter-spacing: 1px;
  }
  .btn:active { transform: translateY(1px); }

  /* 스타트 오버레이 */
  #intro-video {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    background: #000;
    z-index: 0;
  }
  #intro-skip {
    position: absolute; right: 14px; bottom: 14px;
    padding: 6px 12px;
    background: rgba(0,0,0,0.55);
    color: #fff; font-size: 13px; letter-spacing: 1px;
    border-radius: 16px; cursor: pointer;
    z-index: 2;
  }
  #intro-skip:hover { background: rgba(0,0,0,0.75); }
  #start-overlay .intro-content {
    position: relative;
    z-index: 1;
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  #start-overlay.intro-done .intro-content { display: flex; }
  #start-overlay.intro-done #intro-video { opacity: 0.6; }
  #start-overlay.intro-done #intro-skip { display: none; }
  #cutscene-video {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    background: #000;
    z-index: 0;
  }
  #princess-overlay.video-done #cutscene-video { opacity: 0.55; }
  #princess-overlay .cutscene-content { position: relative; z-index: 1; }
  #cutscene-skip {
    position: absolute; right: 10px; bottom: 10px;
    padding: 5px 10px;
    background: rgba(0,0,0,0.6);
    color: #fff; font-size: 12px; letter-spacing: 1px;
    border-radius: 14px; cursor: pointer;
    z-index: 2;
  }
  #cutscene-skip:hover { background: rgba(0,0,0,0.8); }
  #princess-overlay .cutscene-content {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    margin-top: 14px;
  }
  #princess-overlay.video-done .cutscene-content { display: flex; }
  #princess-overlay.video-done #cutscene-skip { display: none; }
  .intro-timer {
    color: #ffe68a;
    font-size: 16px;
    font-weight: bold;
    text-shadow: 0 1px 4px rgba(0,0,0,0.9);
    letter-spacing: 1px;
  }
  .intro-timer b { color: #ffd84d; font-size: 20px; }
  #start-overlay { background: rgba(0,0,15,0.6); }
  #start-overlay .cutscene-title {
    color: #fff;
    text-shadow: 0 2px 6px rgba(0,0,0,0.9), 0 0 18px rgba(80,160,255,0.5);
    font-size: 30px;
    letter-spacing: 2px;
  }
  #start-overlay .cutscene-text {
    color: #e4efff;
    text-shadow: 0 1px 4px rgba(0,0,0,0.9);
    background: rgba(0,0,20,0.35);
    padding: 16px 22px;
    border-radius: 12px;
    backdrop-filter: blur(2px);
    max-width: 460px;
  }
</style>
</head>
<body>
<div id="game-wrap">
  <canvas id="game"></canvas>

  <div id="hud">데스티나의 발자국 : <span class="count" id="count">0</span>/<span id="total">0</span></div>

  <div id="dpad">
    <div class="arrow up"></div>
    <div class="arrow down"></div>
    <div class="arrow left"></div>
    <div class="arrow right"></div>
    <div class="center"></div>
  </div>

  <!-- 시작 오버레이 -->
  <div class="overlay show" id="start-overlay">
    <video id="intro-video" src="데스티나_GIF_이미지_생성.mp4" autoplay muted playsinline preload="auto"></video>
    <div id="intro-skip">영상 건너뛰기 ▶</div>
    <div class="intro-content">
      <div class="cutscene-title">데스티나의 발자취</div>
      <div class="cutscene-text">
        해적선을 피해 대홍수로 사라진 데스티나의 흔적을 찾아가세요.<br>
        데스티나의 흔적을 쫓아 데스티나를 찾아 동료로 섭외할 수 있습니다.
      </div>
      <div class="intro-timer">⏱ 데스티나 구출까지 남은 시간 <b id="intro-timelimit">24시 00분 00초</b></div>
      <button class="btn" id="btn-start">게임 시작</button>
    </div>
  </div>

  <!-- 공주 구출 컷신 -->
  <div class="overlay" id="princess-overlay">
    <video id="cutscene-video" src="ref/서사적_개연성_부족_지적.mp4" muted playsinline preload="auto"></video>
    <div id="cutscene-skip">영상 건너뛰기 ▶</div>
    <div class="cutscene-content">
      <div class="cutscene-title">데스티나 구출 성공!</div>
      <div class="cutscene-text">"감사합니다!<br>앞으로도 항해를 통해 미지의 영역과<br>사라진 동료를 찾아 섭외를 할 수 있습니다."</div>
      <button class="btn" id="btn-close-cutscene">계속하기</button>
    </div>
  </div>

  <!-- 클리어 오버레이 -->
  <div class="overlay" id="clear-overlay">
    <div class="cutscene-title">CLEAR!</div>
    <div class="cutscene-text">데스티나의 발자취를 모두 모았습니다!<br><span id="clear-time"></span></div>
    <button class="btn" id="btn-restart">다시 하기</button>
  </div>
</div>

<script>
(() => {
  const canvas = document.getElementById('game');
  const ctx = canvas.getContext('2d');
  const wrap = document.getElementById('game-wrap');

  const countEl = document.getElementById('count');
  const totalEl = document.getElementById('total');

  // ==== 게임 설정 ====
  const CONFIG = {
    playerSpeed: 2.6,
    pirateSpeed: 1.6,
    playerTurnRate: 0.09,     // rad/frame
    pirateTurnRate: 0.025,    // rad/frame
    pirateWanderMs: 2200,     // ms between wander retargets
    pirateCount: 5,
    stunDuration: 1500, // ms
    invulnDuration: 1500,     // ms after stun
    pickupRadius: 28,
    playerRadius: 22,
    pirateRadius: 24,
    // 선체 실루엣에 맞춘 타원형 충돌 (long = 선수-선미, short = 좌우)
    playerHitLong: 0.95,       // 선박 길이 계수 (radius 대비)
    playerHitShort: 0.55,      // 선박 폭 계수
    pirateHitLong: 1.05,       // 해적선은 좀 더 길쭉
    pirateHitShort: 0.45,      // 노 제외 선체만
    activeResources: 1,        // 필드에 동시에 떠있는 자원 수
    resourceLifetime: 6000,    // 6초 후 재스폰
    resourceGoal: 8,           // 클리어 조건: 수집해야 할 자원 개수 (+공주1)
    warningTime: 2000,         // 말풍선 경고 색 변화 시점 (남은 시간)
    missionTime: 60,           // 시작 UI 안내용 목표 시간 (초)
  };

  let W = 0, H = 0;
  function resize() {
    const rect = wrap.getBoundingClientRect();
    W = rect.width; H = rect.height;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width = Math.round(W * dpr);
    canvas.height = Math.round(H * dpr);
    canvas.style.width = W + 'px';
    canvas.style.height = H + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.imageSmoothingEnabled = true;
    ctx.imageSmoothingQuality = 'high';
  }
  window.addEventListener('resize', resize);
  resize();

  // ==== 엔티티 ====
  const state = {
    running: false,
    startTime: 0,
    clearTime: 0,
    player: null,
    pirates: [],
    items: [],
    princess: null,
    princessRescued: false,
    totalTargets: 0,
    collected: 0,
    splashes: [],
    input: { x: 0, y: 0 },
  };

  const ART = {
    player: Object.assign(new Image(), { src: 'data:image/png;base64,' }),
    pirate: Object.assign(new Image(), { src: 'data:image/png;base64,' }),
    princess: Object.assign(new Image(), { src: 'data:image/png;base64,' }),
    princessPortrait: Object.assign(new Image(), { src: 'data:image/png;base64,' }),
  };
  const ITEM_KINDS = ['footprint'];
  function randomItemPos() {
    return {
      x: 50 + Math.random() * (W - 100),
      y: 100 + Math.random() * (H - 320),
    };
  }
  function randomFarPos(excludeList) {
    for (let i = 0; i < 30; i++) {
      const p = randomItemPos();
      const ok = excludeList.every(o => !o || Math.hypot(o.x - p.x, o.y - p.y) > 90);
      if (ok) return p;
    }
    return randomItemPos();
  }
  function spawnPrincess() {
    const others = state.items.filter(Boolean);
    const pos = randomFarPos([...others, state.player, ...state.pirates]);
    state.princess.x = pos.x;
    state.princess.y = pos.y;
    state.princess.appeared = true;
    state.splashes.push({ x: pos.x, y: pos.y, start: performance.now() });
  }

  function spawnResource(slotIdx) {
    const others = state.items.filter((_, i) => i !== slotIdx);
    const pos = randomFarPos([...others, state.player, state.princess]);
    state.items[slotIdx] = {
      x: pos.x, y: pos.y,
      kind: ITEM_KINDS[Math.floor(Math.random() * ITEM_KINDS.length)],
      expireAt: performance.now() + CONFIG.resourceLifetime,
    };
    state.splashes.push({ x: pos.x, y: pos.y, start: performance.now() });
  }

  // 이미지 대신 Canvas 도형으로 드로잉 (아트웍 플레이스홀더)
  function drawBoat(x, y, radius, glowColor, bodyColor) {
    ctx.save();
    // glow
    ctx.shadowColor = glowColor;
    ctx.shadowBlur = 20;
    // hull
    ctx.fillStyle = bodyColor;
    ctx.strokeStyle = '#3a2410';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.ellipse(x, y, radius * 0.75, radius, 0, 0, Math.PI * 2);
    ctx.fill();
    ctx.stroke();
    ctx.shadowBlur = 0;
    // mast/plank detail
    ctx.fillStyle = '#5a3a1c';
    ctx.fillRect(x - radius * 0.55, y - 2, radius * 1.1, 4);
    ctx.fillRect(x - 2, y - radius * 0.7, 4, radius * 1.4);
    ctx.restore();
  }

  function drawShipImage(img, x, y, radius, glowColor, fallbackBody, heading) {
    ctx.save();
    if (img && img.complete && img.naturalWidth) {
      ctx.shadowColor = glowColor;
      ctx.shadowBlur = 20;
      const sz = radius * 2.2;
      ctx.translate(x, y);
      // sprite bow points up (-Y), so add PI/2 so heading=0 (right) draws bow right
      ctx.rotate((heading != null ? heading : -Math.PI / 2) + Math.PI / 2);
      ctx.drawImage(img, -sz/2, -sz/2, sz, sz);
    } else {
      drawBoat(x, y, radius, glowColor, fallbackBody);
    }
    ctx.restore();
  }

  function drawPlayer(p) {
    const nowD = performance.now();
    const invuln = !p.stunned && nowD < p.invulnUntil;
    // blink at 10Hz while invulnerable
    if (invuln && Math.floor(nowD / 100) % 2 === 0) {
      ctx.save(); ctx.globalAlpha = 0.45;
      drawShipImage(ART.player, p.x, p.y, CONFIG.playerRadius, '#7ad1ff', '#a6743a', p.heading);
      ctx.restore();
    } else {
      drawShipImage(ART.player, p.x, p.y, CONFIG.playerRadius,
        p.stunned ? '#ff4b4b' : (invuln ? '#7ad1ff' : '#f7ff4d'), '#a6743a', p.heading);
    }
    if (p.stunned) {
      ctx.fillStyle = '#fff';
      ctx.font = 'bold 16px sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('★', p.x - 8, p.y - CONFIG.playerRadius - 4);
      ctx.fillText('★', p.x + 8, p.y - CONFIG.playerRadius - 4);
    }
  }

  function drawPirate(p) {
    drawShipImage(ART.pirate, p.x, p.y, CONFIG.pirateRadius, '#ff8a2a', '#8a5a2a', p.heading);
  }

  function drawItem(it) {
    ctx.save();
    // 그림자
    ctx.fillStyle = 'rgba(0,0,0,0.2)';
    ctx.beginPath();
    ctx.ellipse(it.x, it.y + 18, 16, 5, 0, 0, Math.PI * 2);
    ctx.fill();

    // 발자국 (좌우 번갈아 나오도록 id 기반 seed)
    const seed = (it.x * 31 + it.y * 17) | 0;
    const flipped = (seed & 1) === 0;
    drawFootprint(it.x, it.y, 20, flipped, '#5c4030', 1);
    ctx.restore();

    // 말풍선 (자원 타입 + 타이머)
    const remain = it.expireAt - performance.now();
    const warning = remain < CONFIG.warningTime;
    const bx = it.x + 22, by = it.y - 22;
    ctx.save();
    ctx.fillStyle = warning ? '#ffe1e1' : '#fff';
    ctx.strokeStyle = warning ? '#d93b3b' : '#2f4a5c';
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    ctx.moveTo(bx - 10, by + 6);
    ctx.lineTo(bx - 16, by + 13);
    ctx.lineTo(bx - 4, by + 10);
    ctx.closePath();
    ctx.fill(); ctx.stroke();
    ctx.beginPath();
    ctx.arc(bx, by, 14, 0, Math.PI * 2);
    ctx.fill(); ctx.stroke();
    drawFootprint(bx, by, 9, false, '#5c4030', 1);
    const ratio = Math.max(0, remain / CONFIG.resourceLifetime);
    ctx.strokeStyle = warning ? '#ff4b4b' : '#ffd84d';
    ctx.lineWidth = 3.5;
    ctx.beginPath();
    ctx.arc(bx, by, 17, -Math.PI / 2, -Math.PI / 2 + Math.PI * 2 * ratio);
    ctx.stroke();
    ctx.restore();
  }

  const WAKES = [];
  const WAKE_LIFE = 1200;
  function pushWake(x, y, r) {
    WAKES.push({ x, y, r, t: performance.now() });
    if (WAKES.length > 240) WAKES.splice(0, WAKES.length - 240);
  }
  function drawWakes(now) {
    ctx.save();
    for (let i = WAKES.length - 1; i >= 0; i--) {
      const w = WAKES[i];
      const age = now - w.t;
      if (age > WAKE_LIFE) { WAKES.splice(i, 1); continue; }
      const p = age / WAKE_LIFE;
      const rr = w.r * (1 + p * 1.6);
      ctx.globalAlpha = (1 - p) * 0.45;
      ctx.strokeStyle = '#ffffff';
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.arc(w.x, w.y, rr, 0, Math.PI * 2);
      ctx.stroke();
    }
    ctx.restore();
  }

  function drawFootprint(x, y, size, flipped, color, alpha) {
    ctx.save();
    ctx.globalAlpha = alpha != null ? alpha : 1;
    ctx.translate(x, y);
    if (flipped) ctx.scale(-1, 1);
    ctx.fillStyle = color;
    const s = size / 20;
    // heel (oval)
    ctx.beginPath();
    ctx.ellipse(0, 4 * s, 5.5 * s, 8 * s, 0, 0, Math.PI * 2);
    ctx.fill();
    // ball of foot
    ctx.beginPath();
    ctx.ellipse(1 * s, -4 * s, 4.5 * s, 4 * s, 0, 0, Math.PI * 2);
    ctx.fill();
    // toes
    const toes = [[3.2,-9,1.3],[1.2,-10.5,1.1],[-0.8,-11,1.0],[-2.4,-10.5,0.9],[-3.8,-9.4,0.8]];
    for (const [tx,ty,tr] of toes) {
      ctx.beginPath();
      ctx.ellipse(tx * s, ty * s, tr * s, tr * s * 1.15, 0, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.restore();
  }

  function drawSplash(sp) {
    const age = performance.now() - sp.start;
    const life = 600;
    const t = age / life;
    ctx.save();
    ctx.globalAlpha = 1 - t;
    ctx.strokeStyle = '#fff';
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.arc(sp.x, sp.y, 6 + t * 28, 0, Math.PI * 2);
    ctx.stroke();
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.arc(sp.x, sp.y, 2 + t * 18, 0, Math.PI * 2);
    ctx.stroke();
    ctx.restore();
  }

  function drawPrincess(pr) {
    ctx.save();
    // 물에 빠진 통
    ctx.fillStyle = '#a6743a';
    ctx.strokeStyle = '#3a2410';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.ellipse(pr.x, pr.y + 8, 20, 10, 0, 0, Math.PI * 2);
    ctx.fill(); ctx.stroke();
    // 공주 아이콘 (3D 렌더)
    const img = ART.princess;
    const sz = 36;
    if (img && img.complete && img.naturalWidth) {
      ctx.drawImage(img, pr.x - sz/2, pr.y - sz/2 - 6, sz, sz);
    } else {
      ctx.fillStyle = '#ffd84d';
      ctx.beginPath();
      ctx.arc(pr.x, pr.y - 14, 10, 0, Math.PI * 2); ctx.fill();
    }
    ctx.restore();

    // ---- 말풍선 (발자국 스타일, 빨간 테두리 + 느낌표) ----
    const bobY = Math.sin(performance.now() / 400) * 2;
    const bx = pr.x + 22, by = pr.y - 32 + bobY;
    const R = 16;
    ctx.save();
    // 꼬리
    ctx.fillStyle = '#fff';
    ctx.strokeStyle = '#d93b3b';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(bx - 10, by + 6);
    ctx.lineTo(bx - 16, by + 15);
    ctx.lineTo(bx - 4, by + 10);
    ctx.closePath();
    ctx.fill(); ctx.stroke();
    // 원형 본체
    ctx.beginPath();
    ctx.arc(bx, by, R, 0, Math.PI * 2);
    ctx.fill(); ctx.stroke();
    // 초상화 클리핑
    const portrait = ART.princessPortrait;
    if (portrait && portrait.complete && portrait.naturalWidth) {
      ctx.save();
      ctx.beginPath();
      ctx.arc(bx, by, R - 2, 0, Math.PI * 2);
      ctx.clip();
      const pSize = (R - 2) * 2;
      ctx.drawImage(portrait, bx - pSize/2, by - pSize/2, pSize, pSize);
      ctx.restore();
    }
    // 느낌표 (우상단 뱃지)
    const blink = (Math.sin(performance.now() / 250) + 1) / 2;
    const ex = bx + R * 0.75, ey = by - R * 0.75;
    const rCol = (220 + blink * 35) | 0;
    const gbCol = (40 - blink * 10) | 0;
    ctx.fillStyle = 'rgb(' + rCol + ',' + gbCol + ',' + gbCol + ')';
    ctx.strokeStyle = '#fff';
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    ctx.arc(ex, ey, 8, 0, Math.PI * 2);
    ctx.fill(); ctx.stroke();
    ctx.fillStyle = '#fff';
    ctx.font = 'bold 12px sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText('!', ex, ey + 0.5);
    ctx.restore();
  }

  // ==== 초기화 ====
  function initGame() {
    state.player = { x: W / 2, y: H - 160, stunned: false, stunUntil: 0, invulnUntil: 0, heading: -Math.PI / 2, speed: 0, hasInput: false };
    state.pirates = [];
    state.items = [];
    state.princessRescued = false;
    state.collected = 0;

    // 해적선: 랜덤 위치/방향
    for (let i = 0; i < CONFIG.pirateCount; i++) {
      const angle = Math.random() * Math.PI * 2;
      state.pirates.push({
        x: 60 + Math.random() * (W - 120),
        y: 80 + Math.random() * (H - 300),
        heading: angle,
        desired: angle,
        nextWander: performance.now() + Math.random() * CONFIG.pirateWanderMs,
      });
    }

    // 공주 (상단 고정, 수집 시 컷신)
    state.princess = {
      x: W / 2,
      y: 120,
      appeared: false,
      collected: false,
    };

    // 자원 슬롯 준비 후 스폰
    state.items = new Array(CONFIG.activeResources).fill(null);
    state.splashes = [];
    for (let i = 0; i < CONFIG.activeResources; i++) {
      spawnResource(i);
    }

    state.totalTargets = CONFIG.resourceGoal;
    totalEl.textContent = state.totalTargets;
    countEl.textContent = 0;

    state.startTime = performance.now();
    state.running = true;
  }

  // ==== 업데이트 ====
  function angleDiff(a, b) {
    let d = a - b;
    while (d > Math.PI) d -= Math.PI * 2;
    while (d < -Math.PI) d += Math.PI * 2;
    return d;
  }

  function updatePlayer(dt) {
    const p = state.player;
    const now = performance.now();
    if (p.stunned && now >= p.stunUntil) {
      p.stunned = false;
      p.invulnUntil = now + CONFIG.invulnDuration;
    }
    const mag = Math.hypot(state.input.x, state.input.y);
    if (!p.stunned) {
      if (mag > 0.05) {
        p.hasInput = true;
        const desired = Math.atan2(state.input.y, state.input.x);
        const diff = angleDiff(desired, p.heading);
        const turn = Math.max(-CONFIG.playerTurnRate, Math.min(CONFIG.playerTurnRate, diff));
        p.heading += turn;
        const align = Math.max(0, Math.cos(diff));
        const targetSpeed = mag * CONFIG.playerSpeed * (0.4 + 0.6 * align);
        // accelerate toward target speed
        p.speed += (targetSpeed - p.speed) * 0.15;
      } else if (p.hasInput) {
        // no input: keep momentum along current heading (straight-line drift)
        // minor water drag
        p.speed *= 0.995;
      }
      if (p.speed > 0.05) {
        p.x += Math.cos(p.heading) * p.speed;
        p.y += Math.sin(p.heading) * p.speed;
        if (p.speed > 0.4) pushWake(p.x - Math.cos(p.heading) * CONFIG.playerRadius * 0.8,
                                    p.y - Math.sin(p.heading) * CONFIG.playerRadius * 0.8,
                                    CONFIG.playerRadius * 0.55);
      }
    }
    const prevX = p.x, prevY = p.y;
    p.x = Math.max(CONFIG.playerRadius, Math.min(W - CONFIG.playerRadius, p.x));
    p.y = Math.max(CONFIG.playerRadius, Math.min(H - CONFIG.playerRadius, p.y));
    if (p.x !== prevX || p.y !== prevY) p.speed *= 0.5;
  }

  function updatePirates() {
    const now = performance.now();
    for (const pr of state.pirates) {
      if (now >= pr.nextWander) {
        pr.desired = pr.heading + (Math.random() - 0.5) * Math.PI * 0.9;
        pr.nextWander = now + CONFIG.pirateWanderMs * (0.6 + Math.random() * 0.8);
      }
      // wall avoidance: steer away when close
      const margin = CONFIG.pirateRadius * 3;
      let away = null;
      if (pr.x < margin) away = 0;
      else if (pr.x > W - margin) away = Math.PI;
      else if (pr.y < margin) away = Math.PI / 2;
      else if (pr.y > H - margin) away = -Math.PI / 2;
      if (away !== null) pr.desired = away + (Math.random() - 0.5) * 0.6;

      const diff = angleDiff(pr.desired, pr.heading);
      const turn = Math.max(-CONFIG.pirateTurnRate, Math.min(CONFIG.pirateTurnRate, diff));
      pr.heading += turn;
      pr.x += Math.cos(pr.heading) * CONFIG.pirateSpeed;
      pr.y += Math.sin(pr.heading) * CONFIG.pirateSpeed;
      pushWake(pr.x - Math.cos(pr.heading) * CONFIG.pirateRadius * 0.7,
               pr.y - Math.sin(pr.heading) * CONFIG.pirateRadius * 0.7,
               CONFIG.pirateRadius * 0.45);

      // hard clamp inside playfield (shouldn't trigger often thanks to avoidance)
      if (pr.x < CONFIG.pirateRadius) { pr.x = CONFIG.pirateRadius; pr.heading = 0; }
      if (pr.x > W - CONFIG.pirateRadius) { pr.x = W - CONFIG.pirateRadius; pr.heading = Math.PI; }
      if (pr.y < CONFIG.pirateRadius) { pr.y = CONFIG.pirateRadius; pr.heading = Math.PI / 2; }
      if (pr.y > H - CONFIG.pirateRadius) { pr.y = H - CONFIG.pirateRadius; pr.heading = -Math.PI / 2; }
    }
  }

  function checkCollisions() {
    const p = state.player;

    // 자원 수집 / 타이머 만료 처리
    const now = performance.now();
    for (let i = 0; i < state.items.length; i++) {
      const it = state.items[i];
      if (!it) continue;
      // 수집
      if (Math.hypot(it.x - p.x, it.y - p.y) < CONFIG.pickupRadius) {
        state.splashes.push({ x: it.x, y: it.y, start: now });
        state.collected++;
        countEl.textContent = state.collected;
        if (state.collected < CONFIG.resourceGoal) {
          spawnResource(i);
        } else {
          // all footprints found → princess appears
          state.items[i] = null;
          spawnPrincess();
        }
        continue;
      }
      // 시간 만료 → 랜덤 위치로 재스폰
      if (now >= it.expireAt) {
        state.splashes.push({ x: it.x, y: it.y, start: now });
        spawnResource(i);
      }
    }

    // 공주 구출
    if (state.princess.appeared && !state.princess.collected) {
      if (Math.hypot(state.princess.x - p.x, state.princess.y - p.y) < CONFIG.pickupRadius + 6) {
        state.princess.collected = true;
        state.running = false;
        state.clearTime = (performance.now() - state.startTime) / 1000;
        triggerPrincessCutscene();
      }
    }

    // 해적선 충돌 → 스턴
    const nowC = performance.now();
    if (!p.stunned && nowC >= p.invulnUntil) {
      for (const pr of state.pirates) {
        const dx = p.x - pr.x, dy = p.y - pr.y;
        // pirate heading 로컬 좌표로 투영
        const ca = Math.cos(pr.heading), sa = Math.sin(pr.heading);
        const lx = dx * ca + dy * sa;   // along pirate bow
        const ly = -dx * sa + dy * ca;  // perpendicular
        const sumLong = CONFIG.pirateRadius * CONFIG.pirateHitLong + CONFIG.playerRadius * CONFIG.playerHitLong;
        const sumShort = CONFIG.pirateRadius * CONFIG.pirateHitShort + CONFIG.playerRadius * CONFIG.playerHitShort;
        if ((lx * lx) / (sumLong * sumLong) + (ly * ly) / (sumShort * sumShort) <= 1) {
          p.stunned = true;
          p.stunUntil = nowC + CONFIG.stunDuration;
          // 밀어내기
          const ang = Math.atan2(p.y - pr.y, p.x - pr.x);
          p.x += Math.cos(ang) * 20;
          p.y += Math.sin(ang) * 20;
          break;
        }
      }
    }
  }

  function checkClear() {
    if (state.collected >= state.totalTargets && state.princess.collected) {
      state.running = false;
      state.clearTime = (performance.now() - state.startTime) / 1000;
    }
  }

  // ==== 렌더 ====
  let oceanBgCache = null;
  let oceanBgKey = '';
  function buildOceanBg(w, hgt) {
    const off = document.createElement('canvas');
    off.width = w; off.height = hgt;
    const g = off.getContext('2d');
    const grad = g.createLinearGradient(0, 0, 0, hgt);
    grad.addColorStop(0.0, '#2a7fb8');
    grad.addColorStop(0.4, '#3fa5d8');
    grad.addColorStop(0.75, '#5cc0ea');
    grad.addColorStop(1.0, '#7dd4f2');
    g.fillStyle = grad; g.fillRect(0, 0, w, hgt);
    // subtle caustic spots
    for (let i = 0; i < 40; i++) {
      const cx = Math.random() * w, cy = Math.random() * hgt;
      const r = 40 + Math.random() * 120;
      const rg = g.createRadialGradient(cx, cy, 0, cx, cy, r);
      rg.addColorStop(0, 'rgba(255,255,255,' + (0.05 + Math.random()*0.07) + ')');
      rg.addColorStop(1, 'rgba(255,255,255,0)');
      g.fillStyle = rg; g.beginPath(); g.arc(cx, cy, r, 0, Math.PI*2); g.fill();
    }
    return off;
  }

  function render() {
    const now = performance.now();
    const t = now / 1000;
    ctx.clearRect(0, 0, W, H);
    // --- ocean background (cached) ---
    const key = W + 'x' + H;
    if (oceanBgKey !== key) { oceanBgCache = buildOceanBg(W, H); oceanBgKey = key; }
    ctx.drawImage(oceanBgCache, 0, 0);
    // --- layered waves ---
    ctx.save();
    const layers = [
      { a: 0.28, amp: 2.2, wl: 42, sp: 55, yo: 80,  color: '#eaf7ff' },
      { a: 0.22, amp: 3.0, wl: 62, sp: 35, yo: 130, color: '#ffffff' },
      { a: 0.15, amp: 4.0, wl: 90, sp: 22, yo: 40,  color: '#ffffff' },
    ];
    for (const L of layers) {
      ctx.globalAlpha = L.a;
      ctx.strokeStyle = L.color;
      ctx.lineWidth = 1;
      for (let i = 0; i < Math.ceil(H / 110) + 1; i++) {
        const yy = ((i * 110) + (t * L.sp) % 110 + L.yo) % (H + 110);
        ctx.beginPath();
        ctx.moveTo(0, yy);
        for (let x = 0; x <= W; x += 14) {
          ctx.lineTo(x, yy + Math.sin((x + t * L.sp * 1.5) / L.wl) * L.amp);
        }
        ctx.stroke();
      }
    }
    // sparkles
    ctx.globalAlpha = 0.6;
    ctx.fillStyle = '#ffffff';
    for (let i = 0; i < 28; i++) {
      const px = ((i * 97 + t * 18) % W + W) % W;
      const py = ((i * 53 + t * 9) % H + H) % H;
      const tw = (Math.sin(t * 2.3 + i) + 1) * 0.5;
      const s = 1 + tw * 1.8;
      ctx.globalAlpha = 0.15 + tw * 0.45;
      ctx.beginPath();
      ctx.arc(px, py, s, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.restore();
    drawWakes(now);

    if (!state.player) return;

    // 스플래시 (오래된 것 제거)
    state.splashes = state.splashes.filter(s => performance.now() - s.start < 600);
    for (const s of state.splashes) drawSplash(s);

    // 아이템
    for (const it of state.items) {
      if (it) drawItem(it);
    }
    if (state.princess && state.princess.appeared && !state.princess.collected) drawPrincess(state.princess);
    for (const pr of state.pirates) drawPirate(pr);
    drawPlayer(state.player);
    // --- vignette overlay ---
    ctx.save();
    const vg = ctx.createRadialGradient(W/2, H/2, Math.min(W,H)*0.35, W/2, H/2, Math.max(W,H)*0.7);
    vg.addColorStop(0, 'rgba(0,0,0,0)');
    vg.addColorStop(1, 'rgba(0,10,25,0.55)');
    ctx.fillStyle = vg; ctx.fillRect(0, 0, W, H);
    ctx.restore();
  }

  // ==== 루프 ====
  let lastTime = 0;
  function loop(now) {
    const dt = now - lastTime;
    lastTime = now;
    if (state.running) {
      updatePlayer(dt);
      updatePirates();
      checkCollisions();
    }
    render();
    requestAnimationFrame(loop);
  }

  // ==== 입력 (D-pad 가상 조이스틱) ====
  const dpad = document.getElementById('dpad');
  let dpadActive = false;
  let dpadCenter = { x: 0, y: 0 };

  function updateDpadCenter() {
    const r = dpad.getBoundingClientRect();
    dpadCenter.x = r.left + r.width / 2;
    dpadCenter.y = r.top + r.height / 2;
  }

  function handleDpad(cx, cy) {
    const dx = cx - dpadCenter.x;
    const dy = cy - dpadCenter.y;
    const dist = Math.hypot(dx, dy);
    const dead = 10;
    if (dist < dead) { state.input.x = 0; state.input.y = 0; return; }
    const max = 70;
    const clamped = Math.min(dist, max);
    state.input.x = (dx / dist) * (clamped / max);
    state.input.y = (dy / dist) * (clamped / max);
  }

  dpad.addEventListener('pointerdown', (e) => {
    dpadActive = true;
    updateDpadCenter();
    dpad.setPointerCapture(e.pointerId);
    handleDpad(e.clientX, e.clientY);
  });
  dpad.addEventListener('pointermove', (e) => {
    if (!dpadActive) return;
    handleDpad(e.clientX, e.clientY);
  });
  const endDpad = (e) => {
    dpadActive = false;
    state.input.x = 0; state.input.y = 0;
  };
  dpad.addEventListener('pointerup', endDpad);
  dpad.addEventListener('pointercancel', endDpad);
  dpad.addEventListener('pointerleave', endDpad);

  // 키보드 입력 비활성화 - D-pad 드래그만 허용

  // ==== 오버레이 ====
  const startOverlay = document.getElementById('start-overlay');
  const princessOverlay = document.getElementById('princess-overlay');
  const clearOverlay = document.getElementById('clear-overlay');

  // ---- 인트로 영상 제어 ----
  const introVideo = document.getElementById('intro-video');
  const introSkip = document.getElementById('intro-skip');
  const introTimeLabel = document.getElementById('intro-timelimit');
  if (introTimeLabel) {
    let rescueSecondsLeft = 24 * 3600;
    const pad2 = (n) => String(n).padStart(2, '0');
    const renderCountdown = () => {
      const hh = (rescueSecondsLeft / 3600) | 0;
      const mm = ((rescueSecondsLeft % 3600) / 60) | 0;
      const ss = rescueSecondsLeft % 60;
      introTimeLabel.textContent = pad2(hh) + '시 ' + pad2(mm) + '분 ' + pad2(ss) + '초';
    };
    renderCountdown();
    setInterval(() => {
      if (rescueSecondsLeft > 0) { rescueSecondsLeft--; renderCountdown(); }
    }, 1000);
  }

  let introRevealed = false;
  function revealIntroContent() {
    if (introRevealed) return;
    introRevealed = true;
    try { introVideo.pause(); } catch(ex) {}
    startOverlay.classList.add('intro-done');
  }

  if (introVideo) {
    introVideo.addEventListener('ended', () => { revealIntroContent(); });
    introVideo.addEventListener('error', (e) => { revealIntroContent(); });
    introVideo.addEventListener('timeupdate', () => {
      if (introVideo.duration && introVideo.currentTime >= introVideo.duration - 0.15) {
        revealIntroContent();
      }
    });
    introVideo.addEventListener('loadedmetadata', () => {
      const ms = (introVideo.duration + 1) * 1000;
      setTimeout(revealIntroContent, ms);
    });
    const p = introVideo.play();
    if (p && p.catch) {
      p.catch((err) => {
        setTimeout(revealIntroContent, 3000);
      });
    }
  } else {
    revealIntroContent();
  }

  if (introSkip) {
    const skipHandler = (e) => {
      e.preventDefault();
      e.stopPropagation();
      try {
        if (introVideo.duration && isFinite(introVideo.duration)) {
          introVideo.currentTime = Math.max(0, introVideo.duration - 0.05);
        }
      } catch(ex) {}
      revealIntroContent();
    };
    introSkip.addEventListener('click', skipHandler);
    introSkip.addEventListener('pointerdown', skipHandler);
    introSkip.addEventListener('touchstart', skipHandler, { passive: false });
  }

  // 최종 안전장치: 최대 20초 후 강제 공개
  setTimeout(revealIntroContent, 20000);

  document.getElementById('btn-start').addEventListener('click', (e) => {
    startOverlay.classList.remove('show');
    e.currentTarget.blur();
    document.getElementById('hud').classList.add('visible');
    document.getElementById('dpad').classList.add('visible');
    initGame();
  });

  const cutsceneVideo = document.getElementById('cutscene-video');
  const cutsceneSkip = document.getElementById('cutscene-skip');
  let cutsceneRevealed = false;
  function revealCutsceneContent() {
    if (cutsceneRevealed) return;
    cutsceneRevealed = true;
    try { cutsceneVideo.pause(); } catch(e) {}
    princessOverlay.classList.add('video-done');
  }
  if (cutsceneVideo) {
    cutsceneVideo.addEventListener('ended', revealCutsceneContent);
    cutsceneVideo.addEventListener('error', revealCutsceneContent);
    cutsceneVideo.addEventListener('timeupdate', () => {
      if (cutsceneVideo.duration && cutsceneVideo.currentTime >= cutsceneVideo.duration - 0.15) {
        revealCutsceneContent();
      }
    });
    cutsceneVideo.addEventListener('loadedmetadata', () => {
      setTimeout(revealCutsceneContent, (cutsceneVideo.duration + 1) * 1000);
    });
  }
  if (cutsceneSkip) {
    const csSkip = (e) => {
      e.preventDefault(); e.stopPropagation();
      try {
        if (cutsceneVideo.duration && isFinite(cutsceneVideo.duration)) {
          cutsceneVideo.currentTime = Math.max(0, cutsceneVideo.duration - 0.05);
        }
      } catch(ex) {}
      revealCutsceneContent();
    };
    cutsceneSkip.addEventListener('click', csSkip);
    cutsceneSkip.addEventListener('pointerdown', csSkip);
    cutsceneSkip.addEventListener('touchstart', csSkip, { passive: false });
  }

  function triggerPrincessCutscene() {
    state.running = false;
    cutsceneRevealed = false;
    princessOverlay.classList.remove('video-done');
    princessOverlay.classList.add('show');
    if (cutsceneVideo) {
      try {
        cutsceneVideo.currentTime = 0;
        const pl = cutsceneVideo.play();
        if (pl && pl.catch) pl.catch(() => setTimeout(revealCutsceneContent, 3000));
      } catch(e) { revealCutsceneContent(); }
    } else {
      revealCutsceneContent();
    }
    setTimeout(() => { if (!princessOverlay.classList.contains('video-done')) revealCutsceneContent(); }, 20000);
  }
  document.getElementById('btn-close-cutscene').addEventListener('click', () => {
    princessOverlay.classList.remove('show');
    if (state.princess.collected) {
      showClear();
    } else {
      state.running = true;
    }
  });

  function showClear() {
    document.getElementById('clear-time').textContent = `클리어 시간: ${state.clearTime.toFixed(1)}초`;
    clearOverlay.classList.add('show');
  }
  document.getElementById('btn-restart').addEventListener('click', () => {
    clearOverlay.classList.remove('show');
    initGame();
  });

  requestAnimationFrame(loop);
})();
</script>
</body>
</html>
